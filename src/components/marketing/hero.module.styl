.hero
  padding 6rem 0
  text-align center

  @media (max-width: 768px)
    padding 3rem 0

.heroContent
  max-width 800px
  margin 0 auto

.edition
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.75rem
  font-weight 600
  text-transform uppercase
  letter-spacing 0.15em
  color #666E80
  margin-bottom 1.5rem

.headline
  font-family var(--font-playfair), Georgia, 'Times New Roman', serif
  font-size 3.5rem
  font-weight 900
  line-height 1.1
  letter-spacing -0.02em
  color #1A1A2E
  margin 0

  @media (max-width: 768px)
    font-size 2.25rem

.subheadline
  font-family var(--font-baskerville), Georgia, 'Times New Roman', serif
  font-size 1.25rem
  line-height 1.7
  color #666E80
  max-width 600px
  margin 0 auto

  @media (max-width: 768px)
    font-size 1.1rem

.ctaGroup
  display flex
  align-items center
  justify-content center
  gap 1rem
  margin-top 2.5rem
  flex-wrap wrap

