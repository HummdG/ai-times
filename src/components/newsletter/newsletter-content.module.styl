.container
  display grid
  grid-template-columns 1fr
  gap 3rem

  @media (min-width: 1024px)
    grid-template-columns 1fr 300px

.mainContent
  min-width 0

.masthead
  text-align center

.mastheadLabel
  font-family var(--font-playfair), Georgia, 'Times New Roman', serif
  font-size 1rem
  font-weight 700
  letter-spacing 0.05em
  text-transform uppercase
  color #1A1A2E
  margin-bottom 0.25rem

.mastheadMeta
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.75rem
  color #666E80
  letter-spacing 0.05em
  text-transform uppercase

.title
  font-family var(--font-playfair), Georgia, 'Times New Roman', serif
  font-size 2.5rem
  font-weight 900
  line-height 1.1
  letter-spacing -0.02em
  color #1A1A2E
  text-align center

  @media (max-width: 768px)
    font-size 1.75rem

.editorial
  max-width 680px
  margin 0 auto

.editorialParagraph
  font-family var(--font-baskerville), Georgia, 'Times New Roman', serif
  font-size 1.125rem
  line-height 1.8
  color #1A1A2E
  font-style italic
  margin-bottom 1.25rem

.section
  margin-bottom 3rem

.itemList
  display flex
  flex-direction column
  gap 2rem

.item
  padding-bottom 2rem
  border-bottom 1px solid #F2DFCE

  &:last-child
    border-bottom none
    padding-bottom 0

.itemTitle
  margin 0 0 0.5rem 0

.itemTitleLink
  font-family var(--font-playfair), Georgia, 'Times New Roman', serif
  font-size 1.25rem
  font-weight 700
  line-height 1.3
  color #1A1A2E
  text-decoration none
  transition color 0.15s ease

  &:hover
    color #0D7680
    text-decoration underline

.itemSummary
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.9375rem
  line-height 1.7
  color #1A1A2E
  margin 0 0 0.75rem 0

.itemMeta
  display flex
  align-items center
  gap 1rem
  flex-wrap wrap

.sourceName
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.8125rem
  color #666E80

.readMore
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.8125rem
  color #0D7680
  text-decoration none
  display inline-flex
  align-items center

  &:hover
    text-decoration underline

.sidebar
  display none

  @media (min-width: 1024px)
    display block

.sidebarSticky
  position sticky
  top 6rem

.sidebarSection
  margin-bottom 2rem

.tocCategory
  padding 0.5rem 0
  border-bottom 1px solid #F2DFCE

.tocCategoryLabel
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.875rem
  font-weight 500
  color #1A1A2E
  margin 0

.tocCount
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.75rem
  color #9DA3AE
  margin 0.125rem 0 0 0

.sidebarText
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.875rem
  color #666E80
  line-height 1.5
  margin-bottom 1rem

