.container
  display grid
  grid-template-columns 1fr
  gap 3rem

  @media (min-width: 1024px)
    grid-template-columns 1fr 300px

.mainContent
  min-width 0

.masthead
  text-align center

.mastheadLabel
  font-family var(--font-playfair), Georgia, 'Times New Roman', serif
  font-size 1rem
  font-weight 700
  letter-spacing 0.05em
  text-transform uppercase
  color #1A1A2E
  margin-bottom 0.25rem

.mastheadMeta
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.75rem
  color #666E80
  letter-spacing 0.05em
  text-transform uppercase

.title
  font-family var(--font-playfair), Georgia, 'Times New Roman', serif
  font-size 2.5rem
  font-weight 900
  line-height 1.1
  letter-spacing -0.02em
  color #1A1A2E
  text-align center

  @media (max-width: 768px)
    font-size 1.75rem

.mediaSection
  margin 2rem 0

.videoWrapper
  position relative
  width 100%
  aspect-ratio 16 / 9
  background #1A1A2E
  border-radius 8px
  overflow hidden

.video
  width 100%
  height 100%
  object-fit contain

.audioWrapper
  padding 2rem
  background #FFF8F5
  border 1px solid #E8D6C4
  border-radius 8px

.audio
  width 100%
  height 48px

.linksSection
  margin-bottom 3rem

.linkList
  list-style none
  padding 0
  margin 0
  display flex
  flex-direction column
  gap 1.25rem

.linkItem
  padding-bottom 1.25rem
  border-bottom 1px solid #F2DFCE

  &:last-child
    border-bottom none
    padding-bottom 0

.linkTitle
  font-family var(--font-playfair), Georgia, 'Times New Roman', serif
  font-size 1.125rem
  font-weight 700
  line-height 1.3
  color #1A1A2E
  text-decoration none
  display inline-flex
  align-items center
  transition color 0.15s ease

  &:hover
    color #0D7680
    text-decoration underline

.sourceName
  display block
  font-family var(--font-inter), system-ui, sans-serif
  font-size 0.8125rem
  color #666E80
  margin-top 0.25rem

.sidebar
  display none

  @media (min-width: 1024px)
    display block

.sidebarSticky
  position sticky
  top 6rem

.sidebarSection
  margin-bottom 2rem
